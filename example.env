# ============================================
# AI Smart Local Commerce Communication Platform
# Environment Configuration
# ============================================
# Leave keys empty or as placeholders to use
# the open-source fallback providers automatically.
# Add real keys to switch to production APIs.
# ============================================

# --- Database ---
# PostgreSQL (used by Docker): postgresql://commerce:commerce123@postgres:5432/commerce_db
# SQLite (local dev, auto-fallback):
DATABASE_URL=

# --- Redis (optional, in-memory fallback) ---
REDIS_URL=

# --- Twilio (Voice Calls) ---
# If set → TwilioVoiceProvider + TwilioSpeechProvider
# If empty → LocalVoiceProvider + WhisperSpeechProvider
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- ElevenLabs (Text-to-Speech) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Meta WhatsApp Cloud API ---
# If set → WhatsAppCloudProvider
# If empty → LocalMessagingProvider
WHATSAPP_API_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Shopify ---
SHOPIFY_WEBHOOK_SECRET=

# --- WooCommerce ---
WOOCOMMERCE_WEBHOOK_SECRET=

# --- App Settings ---
APP_BASE_URL=http://localhost:8000
APP_ENV=development
